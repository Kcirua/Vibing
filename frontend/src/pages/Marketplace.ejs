<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnAu Farms</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #F9FAFB; }
        .theme-green { color: #165B33; }
        .bg-theme-green { background-color: #165B33; }
        .hover-bg-theme-green:hover { background-color: #0f4224; }
        input[type=number]::-webkit-inner-spin-button, input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
    </style>
</head>
<body class="text-gray-900 antialiased overflow-x-hidden min-h-screen flex flex-col relative">

    <!-- NAVBAR -->
    <nav class="absolute top-0 left-0 w-full z-50 px-8 py-6 flex justify-between items-center text-white">
        <div class="text-2xl font-bold text-white tracking-tight">AnAu Farms</div>
        <div class="hidden md:flex space-x-8 font-medium text-sm text-gray-300">
            <!-- <a href="/" class="hover:text-white transition">Home</a> -->
            <a href="/marketplace" class="text-white border-b-2 border-green-400 pb-1">Marketplace</a>
        </div>
        <div class="flex items-center gap-6">
            <button onclick="openCartModal()" class="relative text-2xl hover:scale-110 transition cursor-pointer">🛒<span id="cart-badge" class="absolute -top-2 -right-2 bg-red-500 text-white text-[10px] font-bold w-5 h-5 flex items-center justify-center rounded-full hidden shadow-md">0</span></button>
            <div class="flex items-center gap-3">
                <div id="auth-section" class="flex items-center gap-3"></div>
                <div id="user-icon-container"><div class="w-10 h-10 bg-gray-500/50 rounded-full flex items-center justify-center font-bold shadow-inner text-xl">👤</div></div>
            </div>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <header class="relative w-full h-[60vh] bg-cover bg-center flex items-center px-8 md:px-16" style="background-image: url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?q=80&w=2000&auto=format&fit=crop');">
        <div class="absolute inset-0 bg-black/40"></div>
        <div class="relative z-10 max-w-7xl mx-auto w-full">
            <div class="max-w-2xl text-white">
                <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm border border-white/30 px-4 py-1.5 rounded-full text-xs font-bold mb-4"><span class="w-2 h-2 bg-green-400 rounded-full"></span> Fresh & Local</div>
                <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-4 shadow-sm">Fresh From Farm to Your Table</h1>
                <p class="text-lg md:text-xl text-gray-200 mb-8">Discover the finest organic produce from local farmers directly to your urban business.</p>
            </div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <main class="max-w-7xl mx-auto w-full px-4 md:px-16 py-16 space-y-20">
        <section>
            <div class="mb-8 flex justify-between items-end">
                <div>
                    <!-- <div class="inline-flex items-center gap-2 bg-green-50 text-green-700 px-3 py-1 rounded-full text-xs font-bold mb-3 border border-green-200">Live from Database</div> -->
                    <h2 class="text-3xl font-bold text-gray-900">Our <span class="theme-green">Available Harvest</span></h2>
                </div>
                <p id="total-products-count" class="text-sm font-bold text-gray-500"></p>
            </div>
            <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="col-span-full py-10 text-center"><div class="inline-block w-8 h-8 border-4 border-green-500 border-t-transparent rounded-full animate-spin mb-2"></div><p class="text-gray-500 font-medium">Menarik data dari database...</p></div>
            </div>
        </section>
    </main>

    <button onclick="openCartModal()" class="fixed bottom-8 right-8 z-[90] w-16 h-16 bg-[#165B33] text-white rounded-full flex items-center justify-center shadow-2xl hover:scale-110 hover:-translate-y-2 transition-all duration-300 cursor-pointer border-4 border-white"><span class="text-3xl">🛒</span><span id="floating-cart-badge" class="absolute -top-2 -right-2 bg-red-500 text-white text-xs font-bold w-6 h-6 flex items-center justify-center rounded-full hidden border-2 border-white shadow-sm">0</span></button>

    <div id="toast-notification" class="fixed bottom-28 right-8 bg-white border-l-4 border-[#165B33] shadow-2xl rounded-lg p-4 z-[200] transform translate-y-32 opacity-0 transition-all duration-500 flex items-center gap-3"><span id="toast-message" class="text-gray-800 font-semibold text-sm">Notifikasi</span></div>

    <!-- ========================================== -->
    <!-- MODAL AUTHENTICATION (SPLIT SCREEN DESAIN) -->
    <!-- ========================================== -->
    <div id="auth-modal" class="fixed inset-0 bg-[#EAB35E]/90 z-[150] hidden flex items-center justify-center backdrop-blur-sm p-4">
        
        <button onclick="closeAuthModal()" class="absolute top-6 right-8 text-white hover:text-red-900 text-5xl font-bold z-[160] transition">&times;</button>
        
        <!-- Kartu Utama -->
        <div class="bg-white w-full max-w-5xl md:h-[600px] rounded-3xl shadow-2xl flex flex-col md:flex-row overflow-hidden relative z-10">
            
            <!-- Kiri: Area Form Dinamis -->
            <div class="w-full md:w-1/2 p-10 md:p-14 flex flex-col justify-center bg-white relative">
                <!-- TAMPILAN LOGIN -->
                <div id="form-login-ui">
                    <p class="text-gray-500 font-medium mb-1">Welcome Buyer</p>
                    <h1 class="text-4xl font-black text-gray-900 mb-8 tracking-tight">Log In</h1>

                    <form onsubmit="attemptFakeLogin(event)">
                        <div class="mb-5">
                            <label class="block text-xs font-bold text-gray-700 mb-2">Your Email</label>
                            <input type="email" id="login-email" required class="w-full border border-gray-200 rounded-lg p-3 outline-none focus:border-[#165B33] transition" placeholder="your email">
                        </div>
                        <div class="mb-2">
                            <label class="block text-xs font-bold text-gray-700 mb-2">Password</label>
                            <div class="relative">
                                <input type="password" id="login-password" required class="w-full border border-gray-200 rounded-lg p-3 outline-none focus:border-[#165B33] transition" placeholder="your password">
                            </div>
                        </div>
                        <div class="text-right mb-6">
                            <a href="#" class="text-[11px] text-blue-500 hover:underline font-medium">Lupa kata sandi ?</a>
                        </div>
                        <button type="submit" id="btn-fake-login" class="w-full bg-[#165B33] text-white font-bold py-3.5 rounded-lg hover:bg-[#0f4224] transition shadow-md">
                            Log In
                        </button>
                    </form>
                    <p class="text-center text-xs text-gray-500 mt-6 font-medium">
                        Don't have an account ? <button onclick="switchAuthTab('register')" class="text-[#165B33] font-bold hover:underline">Sign up</button>
                    </p>
                </div>

                <!-- TAMPILAN REGISTER -->
                <div id="form-register-ui" class="hidden">
                    <p class="text-gray-500 font-medium mb-1">Join AnAu Farms</p>
                    <h1 class="text-4xl font-black text-gray-900 mb-6 tracking-tight">Sign Up</h1>

                    <form onsubmit="processRegister(event)" class="space-y-3">
                        <div>
                            <input type="text" id="reg-name" required placeholder="Nama Lengkap" class="w-full border border-gray-200 rounded-lg p-3 focus:outline-none focus:border-[#165B33] text-sm">
                        </div>
                        <div>
                            <input type="email" id="reg-email" required placeholder="Alamat Email" class="w-full border border-gray-200 rounded-lg p-3 focus:outline-none focus:border-[#165B33] text-sm">
                        </div>
                        <div>
                            <input type="number" id="reg-phone" required placeholder="Nomor WhatsApp" class="w-full border border-gray-200 rounded-lg p-3 focus:outline-none focus:border-[#165B33] text-sm">
                        </div>
                        <div class="mb-2">
                            <input type="password" id="reg-password" required placeholder="Password" class="w-full border border-gray-200 rounded-lg p-3 focus:outline-none focus:border-[#165B33] text-sm">
                        </div>
                        <button type="submit" id="btn-register" class="w-full bg-[#165B33] text-white font-bold py-3.5 rounded-lg hover:bg-[#0f4224] transition shadow-md mt-2">
                            Sign Up
                        </button>
                    </form>
                    <p class="text-center text-xs text-gray-500 mt-5 font-medium">
                        Already have an account ? <button onclick="switchAuthTab('login')" class="text-[#165B33] font-bold hover:underline">Log In</button>
                    </p>
                </div>
            </div>

            <!-- Kanan: Ilustrasi Hijau -->
            <div class="hidden md:flex w-1/2 bg-[#165B33] flex-col items-center justify-center p-12 text-center relative overflow-hidden">
                <div class="absolute -top-16 -left-16 w-64 h-64 bg-green-500/20 rounded-full blur-3xl"></div>
                <div class="absolute -bottom-16 -right-16 w-64 h-64 bg-green-900/40 rounded-full blur-3xl"></div>

                <div class="absolute top-8 right-8 text-white text-right">
                    <h2 class="text-2xl font-bold tracking-tight">AnAu Farms</h2>
                    <p class="text-xs text-green-200 font-medium">( Marketplace )</p>
                </div>

                <img src="https://cdni.iconscout.com/illustration/premium/thumb/farmers-working-in-farm-4328221-3603126.png" alt="Farmers Illustration" class="w-4/5 object-contain mb-8 z-10 relative drop-shadow-2xl filter brightness-110">
                
                <h3 class="text-3xl font-bold text-white mb-3 z-10 relative">Get the best premium food</h3>
                <p class="text-green-100 text-sm z-10 relative px-4 max-w-sm leading-relaxed">
                    You can get the best premium food with the best price directly from local farmers only in HERE !
                </p>
            </div>
        </div>
    </div>


    <!-- MODAL TAMBAH KE KERANJANG -->
    <div id="add-to-cart-modal" class="fixed inset-0 bg-black/60 z-[120] hidden flex items-center justify-center backdrop-blur-sm px-4">
        <div class="bg-white rounded-3xl p-8 max-w-sm w-full shadow-2xl relative text-center">
            <div class="w-16 h-16 bg-green-50 rounded-full flex items-center justify-center text-3xl mx-auto mb-4 border border-green-100">🛒</div>
            <h3 id="add-modal-name" class="text-xl font-bold text-gray-900 mb-1">Nama Produk</h3>
            <p id="add-modal-price" class="text-theme-green font-bold text-lg mb-6">Rp 0 / kg</p>
            <label class="block text-sm font-bold text-gray-500 mb-3">Tentukan Jumlah (Kg)</label>
            <div class="flex items-center justify-center gap-4 mb-2">
                <button onclick="changeAddQty(-1)" class="w-12 h-12 rounded-full bg-gray-100 hover:bg-gray-200 font-black text-2xl text-gray-600 flex items-center justify-center transition shadow-inner">-</button>
                <input type="number" id="add-qty" class="w-20 text-center text-4xl font-black text-gray-900 bg-transparent border-none outline-none" value="1" readonly>
                <button onclick="changeAddQty(1)" class="w-12 h-12 rounded-full bg-gray-100 hover:bg-gray-200 font-black text-2xl text-gray-600 flex items-center justify-center transition shadow-inner">+</button>
            </div>
            <p id="add-modal-stock" class="text-xs font-bold text-gray-400 mb-8">Sisa stok: 0 kg</p>
            <div class="flex gap-3">
                <button onclick="closeAddModal()" class="flex-1 text-gray-500 font-bold py-3 hover:bg-gray-50 rounded-xl transition border border-gray-200">Batal</button>
                <button onclick="confirmAddToCart()" class="flex-1 bg-theme-green text-white font-bold py-3 rounded-xl hover-bg-theme-green transition shadow-md">Masukkan</button>
            </div>
        </div>
    </div>

    <!-- MODAL PRODUCT DETAIL -->
    <div id="product-detail-modal" class="fixed inset-0 bg-black/60 z-[110] hidden flex items-center justify-center backdrop-blur-sm px-4">
        <div class="bg-white rounded-3xl p-8 max-w-md w-full shadow-2xl relative">
            <button onclick="closeProductDetail()" class="absolute top-4 right-4 text-gray-400 hover:text-red-500 font-bold text-2xl transition">&times;</button>
            <div class="w-full h-48 bg-gray-50 rounded-2xl flex items-center justify-center mb-6 border border-gray-100">
                <!-- <div class="text-6xl">📦</div> -->
            </div>
            <div class="flex justify-between items-start mb-2">
                <h3 id="detail-modal-name" class="text-2xl font-bold text-gray-900">Nama Produk</h3>
                <span id="detail-modal-category" class="bg-green-50 text-green-700 text-xs font-bold px-2 py-1 rounded-md">Kategori</span>
            </div>
            <p id="detail-modal-price" class="text-theme-green font-black text-xl mb-4">Rp 0 / kg</p>
            
            <div class="mb-6">
                <h4 class="text-sm font-bold text-gray-700 mb-2">Deskripsi Produk</h4>
                <p id="detail-modal-desc" class="text-gray-600 text-sm leading-relaxed bg-gray-50 p-4 rounded-xl border border-gray-100 min-h-[80px]">
                    Deskripsi tidak tersedia.
                </p>
            </div>
            
            <div class="flex justify-between items-center bg-blue-50 p-3 rounded-xl border border-blue-100 mb-6">
                <span class="text-sm text-blue-800 font-bold">Stok Tersedia:</span>
                <span id="detail-modal-stock" class="text-sm text-blue-900 font-black">0 kg</span>
            </div>
            
            <div id="detail-action-container">
                <!-- Action button (Add to Cart) will be injected here dynamically -->
            </div>
        </div>
    </div>

    <!-- MODAL CHECKOUT CART -->
    <div id="cart-modal" class="fixed inset-0 bg-black/60 z-[100] hidden flex items-center justify-center backdrop-blur-sm px-4">
        <div class="bg-white rounded-3xl p-6 max-w-lg w-full shadow-2xl relative flex flex-col max-h-[85vh]">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-2xl font-bold text-gray-900">Checkout</h2>
                <button onclick="closeCartModal()" class="text-gray-400 hover:text-red-500 font-bold text-2xl transition">&times;</button>
            </div>
            <div id="cart-items-container" class="overflow-y-auto flex-1 space-y-3 mb-2 py-2"></div>
                        <div class="mt-2 pt-4 border-t border-gray-100">
                <label class="block text-sm font-bold text-gray-700 mb-2">Lokasi Pengiriman</label>
                <div class="bg-green-50/50 border border-green-100 rounded-xl p-3 flex items-start gap-3">
                    <div class="text-xl mt-1">📍</div>
                    <div>
                        <h4 class="font-bold text-green-900 text-sm">Universitas Multimedia Nusantara</h4>
                        <p class="text-xs text-green-700 mt-1">Jl. Scientia Boulevard, Gading Serpong, Tangerang, Banten</p>
                        <p class="text-[10px] text-gray-500 mt-2 font-medium italic">*Pengiriman dibatasi area kampus untuk demonstrasi.</p>
                    </div>
                </div>
            </div>
            <div class="mt-4 pt-4 border-t border-gray-100">
                <label class="block text-sm font-bold text-gray-700 mb-2">Metode Pembayaran</label>
                <select id="payment-method" class="w-full border border-gray-300 rounded-xl p-3 outline-none focus:border-green-500 bg-gray-50 font-medium text-gray-700 shadow-sm cursor-pointer">
                    <option value="Transfer Bank (BCA)">Transfer Bank (BCA Virtual Account)</option>
                    <option value="GoPay / OVO">e-Wallet (GoPay / OVO / Dana)</option>
                    <option value="COD (Bayar di Tempat)">COD (Bayar di Tempat)</option>
                </select>
            </div>
            <div class="mt-4 pt-2">
                <div class="flex justify-between items-center mb-4 bg-green-50 p-4 rounded-xl border border-green-100">
                    <span class="text-green-800 font-bold">Total Pembayaran:</span>
                    <span id="cart-total-price" class="text-2xl font-black text-gray-900">Rp 0</span>
                </div>
                <button onclick="processCheckout()" class="w-full bg-[#165B33] text-white font-bold py-3.5 rounded-xl hover:bg-[#0f4224] transition shadow-lg text-lg">Proses Pesanan</button>
            </div>
        </div>
    </div>

    <script>
        let cart = [];
        let tempProduct = null; 

        // ==========================================
        // FUNGSI TOAST NOTIFICATION 
        // ==========================================
        function showToast(message, isError = false) {
            const toast = document.getElementById('toast-notification');
            document.getElementById('toast-message').innerText = message;
            if(isError) toast.classList.replace('border-theme-green', 'border-red-500');
            else toast.classList.replace('border-red-500', 'border-theme-green');
            toast.classList.remove('translate-y-32', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');
            setTimeout(() => { toast.classList.remove('translate-y-0', 'opacity-100'); toast.classList.add('translate-y-32', 'opacity-0'); }, 3000);
        }

        function checkAuthState() { return localStorage.getItem('agrihub_user') ? JSON.parse(localStorage.getItem('agrihub_user')) : null; }

        // ==========================================
        // LOGIKA AUTHENTICATION UI
        // ==========================================
        function renderAuthUI() {
            const authSection = document.getElementById('auth-section');
            const userIcon = document.getElementById('user-icon-container');
            const user = checkAuthState();
            
            if (user) {
                authSection.innerHTML = `<div class="text-right hidden md:block"><p class="text-sm text-white font-bold">${user.name}</p><button onclick="logout()" class="text-xs text-red-300 font-medium hover:text-red-100 transition">Logout</button></div>`;
                userIcon.innerHTML = `<div class="w-10 h-10 bg-green-600 rounded-full flex items-center justify-center text-white font-bold shadow-md text-xl">👤</div>`;
            } else {
                authSection.innerHTML = `<button onclick="openAuthModal()" class="bg-white text-green-900 text-sm font-bold px-5 py-2 rounded-full shadow hover:bg-gray-100 transition">Masuk / Daftar</button>`;
                userIcon.innerHTML = `<div class="w-10 h-10 bg-gray-500/50 rounded-full flex items-center justify-center font-bold opacity-70 text-xl">👤</div>`;
            }
        }

        function openAuthModal() { document.getElementById('auth-modal').classList.remove('hidden'); }
        function closeAuthModal() { document.getElementById('auth-modal').classList.add('hidden'); }
        
        function switchAuthTab(tab) {
            const loginForm = document.getElementById('form-login-ui');
            const registerForm = document.getElementById('form-register-ui');
            if (tab === 'login') { loginForm.classList.remove('hidden'); registerForm.classList.add('hidden'); } 
            else { registerForm.classList.remove('hidden'); loginForm.classList.add('hidden'); }
        }

        // ==========================================
        // FITUR LOGIN (TERHUBUNG KE BACKEND BARU)
        // ==========================================
        async function attemptFakeLogin(e) {
            e.preventDefault();
            const emailInput = document.getElementById('login-email').value;
            const pwdInput = document.getElementById('login-password').value;
            const btn = document.getElementById('btn-fake-login');
            
            btn.innerText = "Mengecek Database..."; btn.disabled = true;

            try {
                // Tembak API Login yang baru dibuat
                const response = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: emailInput, password: pwdInput })
                });
                
                const result = await response.json();

                if (response.ok) {
                    // Berhasil! Ambil data asli dari database
                    const realUser = result.user;
                    
                    localStorage.setItem('agrihub_user', JSON.stringify({ 
                        uid: realUser.uid || realUser.id, 
                        name: realUser.name, 
                        email: realUser.email, 
                        phone: realUser.phone 
                    }));
                    
                    closeAuthModal(); 
                    renderAuthUI(); 
                    loadProductsGrid(); // Buka gembok tombol Add to Cart
                    
                    showToast(`Selamat datang kembali, ${realUser.name}!`);
                } else {
                    showToast("Gagal: " + (result.message || "Email salah"), true);
                }
            } catch (error) {
                showToast("Terjadi kesalahan jaringan server.", true);
            } finally {
                btn.innerText = "Log In"; btn.disabled = false;
            }
        }

        // ==========================================
        // FITUR REGISTER (TERHUBUNG KE BACKEND)
        // ==========================================
        async function processRegister(e) {
            e.preventDefault();
            const btn = document.getElementById('btn-register');
            btn.innerText = "Memproses..."; btn.disabled = true;
            
            const name = document.getElementById('reg-name').value;
            const email = document.getElementById('reg-email').value;
            const phone = document.getElementById('reg-phone').value;
            const password = document.getElementById('reg-password').value;
            
            try {
                const response = await fetch('/api/auth/register', { 
                    method: 'POST', 
                    headers: { 'Content-Type': 'application/json' }, 
                    body: JSON.stringify({ name, email, phone, password, role: 'buyer' }) 
                });
                
                const result = await response.json();
                
                if (response.status === 201) {
                    showToast(`Registrasi berhasil!`);
                    localStorage.setItem('agrihub_user', JSON.stringify({ uid: result.uid, name, email, phone }));
                    closeAuthModal(); 
                    renderAuthUI(); 
                    loadProductsGrid();
                } else showToast("Registrasi gagal: " + (result.message || result.error), true);
            } catch (error) { showToast("Terjadi kesalahan jaringan.", true); } 
            finally { btn.innerText = "Sign Up"; btn.disabled = false; }
        }

        function logout() { 
            localStorage.removeItem('agrihub_user'); 
            cart = []; updateCartUI(); renderAuthUI(); loadProductsGrid(); 
            showToast("Anda telah keluar."); 
        }

        // ==========================================
        // LOGIKA KERANJANG & CHECKOUT
        // ==========================================
        function handleAddToCartClick(id, name, price, maxStock) {
            if (!checkAuthState()) { showToast("Anda harus Login/Daftar terlebih dahulu untuk berbelanja.", true); return openAuthModal(); }
            tempProduct = { id, name, price, maxStock };
            document.getElementById('add-modal-name').innerText = name;
            document.getElementById('add-modal-price').innerText = `Rp ${price.toLocaleString('id-ID')} / Kg`;
            document.getElementById('add-modal-stock').innerText = `Sisa stok di database: ${maxStock} Kg`;
            document.getElementById('add-qty').value = 1; 
            document.getElementById('add-to-cart-modal').classList.remove('hidden');
        }

        function closeAddModal() { document.getElementById('add-to-cart-modal').classList.add('hidden'); tempProduct = null; }

        function changeAddQty(delta) {
            let val = parseInt(document.getElementById('add-qty').value) + delta;
            if (val < 1) val = 1;
            if (val > tempProduct.maxStock) { val = tempProduct.maxStock; showToast(`Maksimal ${tempProduct.maxStock} kg`, true); }
            document.getElementById('add-qty').value = val;
        }

        function confirmAddToCart() {
            const qty = parseInt(document.getElementById('add-qty').value);
            const existingItem = cart.find(item => item.productId === tempProduct.id);
            if (existingItem) {
                if (existingItem.quantity + qty <= tempProduct.maxStock) { existingItem.quantity += qty; showToast(`Ditambahkan lagi ke keranjang!`); } 
                else return showToast(`Melebihi batas stok!`, true);
            } else {
                cart.push({ ...tempProduct, quantity: qty }); showToast(`${tempProduct.name} dimasukkan keranjang!`);
            }
            updateCartUI(); closeAddModal();
        }

        function removeCartItem(index) { cart.splice(index, 1); updateCartUI(); }

        function updateQuantityInCart(index, delta) {
            const item = cart[index];
            const newQty = item.quantity + delta;
            if (newQty > 0 && newQty <= item.maxStock) item.quantity = newQty;
            else if (newQty > item.maxStock) showToast(`Stok maksimal ${item.maxStock} Kg`, true);
            updateCartUI();
        }

        function updateCartUI() {
            const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
            ['cart-badge', 'floating-cart-badge'].forEach(id => {
                const el = document.getElementById(id);
                if(totalItems > 0) { el.innerText = totalItems; el.classList.remove('hidden'); } else el.classList.add('hidden');
            });
            const container = document.getElementById('cart-items-container');
            if (cart.length === 0) {
                container.innerHTML = '<p class="text-center text-gray-500 text-sm py-4">Keranjang kosong.</p>';
                document.getElementById('cart-total-price').innerText = 'Rp 0'; return;
            }
            let html = ''; let totalPrice = 0;
            cart.forEach((item, index) => {
                totalPrice += item.price * item.quantity;
                html += `<div class="flex justify-between items-center bg-gray-50 p-3 rounded-xl border border-gray-200"><div class="flex-1"><h4 class="font-bold text-gray-800 text-sm">${item.name}</h4><p class="text-xs text-gray-500">Rp ${item.price.toLocaleString('id-ID')}/Kg</p></div><div class="flex items-center gap-3"><div class="flex items-center bg-white border border-gray-200 rounded-lg text-sm shadow-sm overflow-hidden"><button onclick="updateQuantityInCart(${index}, -1)" class="w-8 h-8 font-bold text-gray-600 hover:bg-gray-100">-</button><span class="w-8 text-center font-bold text-gray-900">${item.quantity}</span><button onclick="updateQuantityInCart(${index}, 1)" class="w-8 h-8 font-bold text-gray-600 hover:bg-gray-100">+</button></div><button onclick="removeCartItem(${index})" class="text-red-400 hover:text-red-600 font-bold ml-1 text-lg">🗑️</button></div></div>`;
            });
            container.innerHTML = html;
            document.getElementById('cart-total-price').innerText = `Rp ${totalPrice.toLocaleString('id-ID')}`;
        }

        function openCartModal() {
            if (!checkAuthState()) { showToast("Login dlu untuk melihat keranjang.", true); return openAuthModal(); }
            updateCartUI(); document.getElementById('cart-modal').classList.remove('hidden');
        }
        function closeCartModal() { document.getElementById('cart-modal').classList.add('hidden'); }

        // ==========================================
        // PROSES PESANAN (MENGGUNAKAN NAMA ASLI DARI DB)
        // ==========================================
        async function processCheckout() {
            if (cart.length === 0) return showToast("Keranjang kosong!", true);
            const user = checkAuthState();
            const paymentMethod = document.getElementById('payment-method').value;
            
            // Payload ini akan dikirim ke Backend, menggunakan nama dan no HP asli dari database user
            const payload = { 
                buyerName: user.name, 
                buyerPhone: user.phone, 
                items: cart.map(i => ({ productId: i.id, quantity: i.quantity })) 
            };
            
            const btn = document.querySelector('button[onclick="processCheckout()"]');
            btn.innerText = "Memproses..."; btn.disabled = true;

            try {
                const response = await fetch('/api/orders', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                if (response.status === 201) {
                    showToast(`Pembayaran via ${paymentMethod} Berhasil!`);
                    cart = []; closeCartModal(); setTimeout(() => window.location.reload(), 2000);
                } else showToast("Gagal membuat pesanan", true);
            } catch (error) { showToast("Terjadi kesalahan jaringan.", true); } 
            finally { btn.innerText = "Proses Pesanan"; btn.disabled = false; }
        }

        // ==========================================
        // FUNGSI PRODUCT DETAIL MODAL
        // ==========================================
        function showProductDetail(index) {
            const product = window.marketProducts[index];
            if (!product) return;
            
            document.getElementById('detail-modal-name').innerText = product.name;
            document.getElementById('detail-modal-category').innerText = product.category || 'General';
            document.getElementById('detail-modal-price').innerText = `Rp ${product.price.toLocaleString('id-ID')} / kg`;
            document.getElementById('detail-modal-desc').innerText = product.description || 'Deskripsi tidak tersedia.';
            document.getElementById('detail-modal-stock').innerText = `${product.stock} kg`;
            
            const user = checkAuthState();
            const actionContainer = document.getElementById('detail-action-container');
            
            if (product.stock === 0) {
                actionContainer.innerHTML = `<button disabled class="w-full bg-gray-400 text-white py-3 rounded-xl font-bold cursor-not-allowed">Habis Terjual</button>`;
            } else if (!user) {
                actionContainer.innerHTML = `<button onclick="closeProductDetail(); handleAddToCartClick()" class="w-full bg-gray-200 text-gray-700 py-3 rounded-xl font-bold hover:bg-gray-300 transition flex items-center justify-center gap-2">Login untuk Beli</button>`;
            } else {
                actionContainer.innerHTML = `<button onclick="closeProductDetail(); handleAddToCartClick('${product.id}', '${product.name}', ${product.price}, ${product.stock})" class="w-full bg-[#165B33] text-white font-bold py-3 rounded-xl hover:bg-[#0f4224] transition shadow-md">🛒 Masukkan ke Keranjang</button>`;
            }
            
            document.getElementById('product-detail-modal').classList.remove('hidden');
        }

        function closeProductDetail() {
            document.getElementById('product-detail-modal').classList.add('hidden');
        }

        // ==========================================
        // FETCH DATA PRODUK (KUNCI TOMBOL JIKA GUEST)
        // ==========================================
        async function loadProductsGrid() {
            const productGrid = document.getElementById('product-grid');
            const user = checkAuthState(); // Mengecek apakah user sudah login
            
            try {
                const response = await fetch('/api/products');
                let rawProducts = await response.json();
                
                // Filter out expired products & calculate daysLeft
                let products = rawProducts.filter(p => {
                    let expireDate;
                    if (p.expireDate) {
                        expireDate = new Date(p.expireDate);
                    } else if (p.createdAt) {
                        const inputDate = new Date(p.createdAt._seconds ? p.createdAt._seconds * 1000 : p.createdAt);
                        expireDate = new Date(inputDate.getTime() + (7 * 24 * 60 * 60 * 1000));
                    } else {
                        return true; // No expiration data, keep it
                    }

                    const today = new Date();
                    today.setHours(0,0,0,0);
                    expireDate.setHours(0,0,0,0);
                    const timeDiff = expireDate.getTime() - today.getTime();
                    p.daysLeft = Math.ceil(timeDiff / (1000 * 3600 * 24));

                    return p.daysLeft >= 0; // Don't show expired
                });

                // Sort so Promo items (daysLeft <= 2) are at the front
                products.sort((a, b) => {
                    const aPromo = (a.daysLeft !== undefined && a.daysLeft <= 2) ? 1 : 0;
                    const bPromo = (b.daysLeft !== undefined && b.daysLeft <= 2) ? 1 : 0;
                    if (aPromo && !bPromo) return -1;
                    if (!aPromo && bPromo) return 1;
                    return 0;
                });

                window.marketProducts = products;
                document.getElementById('total-products-count').innerText = `${products.length} Products Found`;

                if (products.length === 0) { productGrid.innerHTML = '<p class="text-gray-500 col-span-full text-center">Belum ada hasil panen.</p>'; return; }
                productGrid.innerHTML = ''; 
                
                products.forEach((product, index) => {
                    // Promo jika sisa hari <= 2
                    const isPromo = product.daysLeft !== undefined && product.daysLeft <= 2;
                    const isOutOfStock = product.stock === 0;
                    const formattedPrice = new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(product.price);
                    
                    let actionBtn = isOutOfStock 
                        ? `<button disabled onclick="event.stopPropagation()" class="mt-auto w-full bg-gray-400 text-white py-2.5 rounded-lg font-bold text-sm cursor-not-allowed">Habis Terjual</button>`
                        : !user 
                            ? `<button onclick="event.stopPropagation(); handleAddToCartClick()" class="mt-auto w-full bg-gray-200 text-gray-700 py-2.5 rounded-lg font-bold text-sm hover:bg-gray-300 transition flex items-center justify-center gap-2">Login untuk Beli</button>`
                            : `<button onclick="event.stopPropagation(); handleAddToCartClick('${product.id}', '${product.name}', ${product.price}, ${product.stock})" class="mt-auto w-full bg-[#165B33] hover:bg-[#0f4224] text-white py-2.5 rounded-lg font-bold text-sm transition shadow-md">🛒 Add to Cart</button>`;

                    productGrid.innerHTML += `
                        <div onclick="showProductDetail(${index})" class="cursor-pointer bg-white rounded-2xl shadow-sm border ${isPromo ? 'border-blue-200 border-2' : 'border-gray-100'} overflow-hidden flex flex-col group relative ${isOutOfStock ? 'opacity-60 grayscale' : 'hover:shadow-lg transition'}">
                            ${isOutOfStock ? `<div class="absolute inset-0 bg-white/50 z-20 flex items-center justify-center"><span class="bg-red-600 text-white font-black px-6 py-2 rounded-lg text-lg transform -rotate-12 border-2 border-white shadow-xl">HABIS</span></div>` : isPromo ? `<div class="absolute top-6 -right-10 bg-blue-500 text-white text-xs font-bold px-10 py-1 rotate-45 shadow-sm z-20">PROMO </div>` : `<div class="absolute top-3 left-3 bg-orange-500 text-white text-xs font-bold px-2 py-1 rounded shadow-sm z-10">Featured</div>`}
                            <div class="w-full h-48 bg-gray-50 relative flex items-center justify-center overflow-hidden"><div class="text-6xl group-hover:scale-110 transition duration-500">📦</div></div>
                            <div class="p-5 flex-1 flex flex-col z-10 bg-white">
                                <h3 class="font-bold text-gray-900 text-lg">${product.name}</h3>
                                <p class="text-xs ${isPromo ? 'text-blue-600 font-bold' : 'text-gray-500'} mt-1">Sisa Stok: ${product.stock} kg</p>
                                <div class="mt-4 flex justify-between items-end mb-5">
                                    <p class="font-bold text-xl ${isPromo ? 'text-blue-600' : 'text-gray-900'}">${formattedPrice}<span class="text-xs font-normal">/kg</span></p>
                                    <span class="text-[10px] text-gray-500 font-bold bg-gray-100 border border-gray-200 px-2 py-1 rounded-md truncate max-w-[80px]">${product.category || 'General'}</span>
                                </div>
                                ${actionBtn}
                            </div>
                        </div>`;
                });
            } catch (error) { productGrid.innerHTML = '<p class="text-red-500 col-span-full text-center font-bold">Gagal mengambil data.</p>'; }
        }

        document.addEventListener("DOMContentLoaded", () => { renderAuthUI(); loadProductsGrid(); });
    </script>
</body>
</html>