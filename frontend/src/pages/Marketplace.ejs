<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.judul || 'AgriHub - B2B Marketplace' %></title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #F9FAFB; }
        .theme-green { color: #3b7b24; }
        .bg-theme-green { background-color: #3b7b24; }
        .hover-bg-theme-green:hover { background-color: #2f631c; }
    </style>
</head>
<body class="text-gray-900 antialiased overflow-x-hidden min-h-screen flex flex-col">

    <!-- NAVBAR -->
    <nav class="absolute top-0 left-0 w-full z-50 px-8 py-6 flex justify-between items-center text-white">
    <!-- <nav class="bg-[#1A3626] w-full z-50 px-8 py-4 flex justify-between items-center text-white shadow-md"> -->
        <div class="text-2xl font-bold text-white tracking-tight">AgriHub</div>
        
        <div class="hidden md:flex space-x-8 font-medium text-sm text-gray-300">
            <a href="/" class="hover:text-white transition">Home</a>
            <a href="/marketplace" class="text-white border-b-2 border-green-400 pb-1">Marketplace</a>
            <a href="#" class="hover:text-white transition">Weather Alerts</a>
            <a href="#" class="hover:text-white transition">Reports</a>
        </div>

        <div class="flex items-center gap-4">
            <span class="text-sm hidden md:block">📍 Tangerang, Banten</span>
            <div class="w-10 h-10 bg-green-700 rounded-full flex items-center justify-center font-bold shadow-inner">
                👨‍🌾
            </div>
        </div>
    </nav>

    <!-- HERO SECTION (Fresh From Farm to Your Table) -->
    <header class="relative w-full h-[60vh] bg-cover bg-center flex items-center px-8 md:px-16" 
            style="background-image: url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?q=80&w=2000&auto=format&fit=crop');">
        <!-- Dark Overlay -->
        <div class="absolute inset-0 bg-black/40"></div>
        
        <div class="relative z-10 max-w-7xl mx-auto w-full">
            <div class="max-w-2xl text-white">
                <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm border border-white/30 px-4 py-1.5 rounded-full text-xs font-bold mb-4">
                    <span class="w-2 h-2 bg-green-400 rounded-full"></span> Fresh & Local
                </div>
                <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-4 shadow-sm">
                    Fresh From Farm to Your Table
                </h1>
                <p class="text-lg md:text-xl text-gray-200 mb-8">
                    Discover the finest organic produce from local farmers directly to your urban business.
                </p>
                <div class="flex gap-4">
                    <button class="bg-theme-green hover-bg-theme-green text-white px-8 py-3 rounded-md font-bold text-sm transition shadow-lg flex items-center gap-2">
                        SHOP NOW
                    </button>
                    <button class="bg-transparent border border-white text-white px-8 py-3 rounded-md font-bold text-sm hover:bg-white/10 transition">
                        LEARN MORE
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <main class="max-w-7xl mx-auto w-full px-4 md:px-16 py-16 space-y-20">
        
        <!-- CATEGORIES SECTION -->
        <section>
            <div class="flex justify-between items-end mb-8">
                <div>
                    <div class="inline-flex items-center gap-2 bg-green-50 text-green-700 px-3 py-1 rounded-full text-xs font-bold mb-3 border border-green-200">
                        🛒 10 Categories Available
                    </div>
                    <h2 class="text-3xl font-bold text-gray-900">
                        Explore Our <span class="theme-green">Product Categories</span>
                    </h2>
                    <p class="text-gray-500 mt-2 text-sm max-w-2xl">Discover fresh, locally-sourced products from trusted farmers in your area. From farm-fresh vegetables to artisanal dairy products.</p>
                </div>
                <button class="hidden md:flex bg-theme-green hover-bg-theme-green text-white px-6 py-2 rounded-md text-sm font-bold transition items-center gap-2">
                    View All Categories
                </button>
            </div>

            <!-- Categories Grid -->
            <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                <!-- Cat 1 -->
                <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition">
                    <div class="h-32 bg-gray-200 flex items-center justify-center text-4xl">🥬</div>
                    <div class="p-4 flex justify-between items-end">
                        <div>
                            <h3 class="font-bold text-gray-900 text-sm">Vegetables</h3>
                            <p class="text-xs text-gray-400 mt-1">12 items</p>
                        </div>
                        <span class="theme-green text-xs font-bold cursor-pointer">Explore</span>
                    </div>
                </div>
                <!-- Cat 2 -->
                <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition">
                    <div class="h-32 bg-gray-200 flex items-center justify-center text-4xl">🍎</div>
                    <div class="p-4 flex justify-between items-end">
                        <div>
                            <h3 class="font-bold text-gray-900 text-sm">Fruits</h3>
                            <p class="text-xs text-gray-400 mt-1">8 items</p>
                        </div>
                        <span class="theme-green text-xs font-bold cursor-pointer">Explore</span>
                    </div>
                </div>
                <!-- Cat 3 -->
                <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition">
                    <div class="h-32 bg-gray-200 flex items-center justify-center text-4xl">🥚</div>
                    <div class="p-4 flex justify-between items-end">
                        <div>
                            <h3 class="font-bold text-gray-900 text-sm">Dairy & Eggs</h3>
                            <p class="text-xs text-gray-400 mt-1">5 items</p>
                        </div>
                        <span class="theme-green text-xs font-bold cursor-pointer">Explore</span>
                    </div>
                </div>
                <!-- Cat 4 -->
                <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition">
                    <div class="h-32 bg-gray-200 flex items-center justify-center text-4xl">🥩</div>
                    <div class="p-4 flex justify-between items-end">
                        <div>
                            <h3 class="font-bold text-gray-900 text-sm">Meat & Poultry</h3>
                            <p class="text-xs text-gray-400 mt-1">0 items</p>
                        </div>
                        <span class="theme-green text-xs font-bold cursor-pointer">Explore</span>
                    </div>
                </div>
                <!-- Cat 5 -->
                <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition">
                    <div class="h-32 bg-gray-200 flex items-center justify-center text-4xl">🍯</div>
                    <div class="p-4 flex justify-between items-end">
                        <div>
                            <h3 class="font-bold text-gray-900 text-sm">Honey & Preserves</h3>
                            <p class="text-xs text-gray-400 mt-1">3 items</p>
                        </div>
                        <span class="theme-green text-xs font-bold cursor-pointer">Explore</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- BEST PICKS SECTION (Products Grid) -->
        <section>
            <div class="mb-8">
                <div class="inline-flex items-center gap-2 bg-green-50 text-green-700 px-3 py-1 rounded-full text-xs font-bold mb-3 border border-green-200">
                    ⭐ Featured Products
                </div>
                <h2 class="text-3xl font-bold text-gray-900">
                    Our <span class="theme-green">Best Picks</span>
                </h2>
                <p class="text-gray-500 mt-2 text-sm">Handpicked fresh products from our trusted farmers. Quality guaranteed, directly from farm to your table.</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                
                <!-- Product 1: Cherry Tomatoes -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden flex flex-col group">
                    <div class="w-full h-56 bg-gray-50 relative flex items-center justify-center">
                        <!-- Orange Featured Badge -->
                        <div class="absolute top-3 left-3 bg-orange-500 text-white text-xs font-bold px-2 py-1 rounded shadow-sm z-10">
                            Featured
                        </div>
                        <!-- Your Image -->
                        <img src="https://i5.walmartimages.com/seo/Fresh-Glorys-Cherry-Tomatoes-10-oz-Package_3ae3b169-d944-49a5-b992-aee078f8d119.3adfa4e3d0f914ef373e3ec1a458623e.png?odnHeight=573&odnWidth=573&odnBg=FFFFFF" alt="Cherry" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                    </div>
                    <div class="p-5 flex-1 flex flex-col">
                        <h3 class="font-bold text-gray-900 text-lg">Cherry Tomatoes</h3>
                        <p class="text-xs text-gray-500 mt-1 line-clamp-1">Freshly harvested sweet cherry tomatoes.</p>
                        
                        <div class="mt-4 flex justify-between items-end mb-4">
                            <p class="font-bold text-xl text-gray-900">Rp 15.000<span class="text-xs font-normal text-gray-500">/kg</span></p>
                            <span class="text-[10px] text-gray-400 font-semibold bg-gray-100 px-2 py-1 rounded">Vegetables</span>
                        </div>
                        
                        <!-- Full width button matching design -->
                        <button class="mt-auto w-full bg-theme-green hover-bg-theme-green text-white py-2.5 rounded-md font-bold text-sm transition flex items-center justify-center gap-2">
                            View
                        </button>
                    </div>
                </div>

                <!-- Product 2: Urgent Surplus (Sawi) -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden flex flex-col group">
                    <div class="w-full h-56 bg-gray-50 relative flex items-center justify-center">
                        <!-- Red Urgent Badge -->
                        <div class="absolute top-3 left-3 bg-red-600 text-white text-xs font-bold px-2 py-1 rounded shadow-sm z-10">
                            50% OFF Urgent
                        </div>
                        <!-- Your Image -->
                        <img src="https://i5.walmartimages.com/asr/589b7ac9-0e80-440d-a33e-ff15b5b6a4c9.d70ff9bc523284f171ee72cdfcd7cd23.jpeg?odnHeight=2000&odnWidth=2000&odnBg=FFFFFF" alt="Sawi" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                    </div>
                    <div class="p-5 flex-1 flex flex-col">
                        <h3 class="font-bold text-gray-900 text-lg">Napa Cabbage (Sawi)</h3>
                        <p class="text-xs text-gray-500 mt-1 line-clamp-1">Surplus harvest. Needs to be sold today.</p>
                        
                        <div class="mt-4 flex justify-between items-end mb-4">
                            <div>
                                <p class="text-xs text-gray-400 line-through">Rp 10.000</p>
                                <p class="font-bold text-xl text-red-600">Rp 5.000<span class="text-xs font-normal text-red-400">/kg</span></p>
                            </div>
                            <span class="text-[10px] text-gray-400 font-semibold bg-gray-100 px-2 py-1 rounded">Vegetables</span>
                        </div>
                        
                        <button class="mt-auto w-full bg-theme-green hover-bg-theme-green text-white py-2.5 rounded-md font-bold text-sm transition flex items-center justify-center gap-2">
                            View
                        </button>
                    </div>
                </div>

                <!-- Product 3: Red Onions -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden flex flex-col group">
                    <div class="w-full h-56 bg-gray-50 relative flex items-center justify-center">
                        <!-- Orange Featured Badge -->
                        <div class="absolute top-3 left-3 bg-orange-500 text-white text-xs font-bold px-2 py-1 rounded shadow-sm z-10">
                            Featured
                        </div>
                        <!-- Your Image -->
                        <img src="https://i5.walmartimages.com/seo/Fresh-Red-Onions-3-lb-Bag_b8779821-a7f0-4d75-bfd5-9d0334545aed.5a8a2800aaa3971b9c0d0047d8a65c23.png?odnHeight=2000&odnWidth=2000&odnBg=FFFFFF" alt="onion" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                    </div>
                    <div class="p-5 flex-1 flex flex-col">
                        <h3 class="font-bold text-gray-900 text-lg">Red Onions</h3>
                        <p class="text-xs text-gray-500 mt-1 line-clamp-1">High-quality dry red onions.</p>
                        
                        <div class="mt-4 flex justify-between items-end mb-4">
                            <p class="font-bold text-xl text-gray-900">Rp 28.000<span class="text-xs font-normal text-gray-500">/kg</span></p>
                            <span class="text-[10px] text-gray-400 font-semibold bg-gray-100 px-2 py-1 rounded">Herbs & Spices</span>
                        </div>
                        
                        <button class="mt-auto w-full bg-theme-green hover-bg-theme-green text-white py-2.5 rounded-md font-bold text-sm transition flex items-center justify-center gap-2">
                            View
                        </button>
                    </div>
                </div>

            </div>
        </section>

    </main>

</body>
</html>