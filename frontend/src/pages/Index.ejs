<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.judul || 'AgriHub - Market & Weather' %></title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        /* Custom Colors matching the new design */
        .text-theme-lime { color: #849f2b; }
        .bg-theme-lime { background-color: #D6E44E; }
        .hover-bg-theme-lime:hover { background-color: #c4d142; }
        .bg-cream { background-color: #FCFBF6; }
    </style>
</head>
<body class="bg-[#F6F7F6] text-gray-900 antialiased overflow-x-hidden">

    <!-- NAVBAR -->
    <nav class="absolute top-0 left-0 w-full z-50 px-8 py-6 flex justify-between items-center text-white">
        <div class="text-2xl font-bold text-green-800 tracking-tight">AgriHub</div>
        
        <div class="hidden md:flex space-x-8 font-medium text-sm text-white">
            <a href="#" class="hover:text-green-300 transition border-b-2 border-white pb-1">Home</a>
            <a href="/marketplace" class="hover:text-green-300 transition">Marketplace</a>
            <a href="#" class="hover:text-green-300 transition">Weather Alerts</a>
            <a href="#" class="hover:text-green-300 transition">Reports</a>
        </div>

        <button class="bg-white text-gray-900 px-6 py-2 rounded-full text-sm font-semibold hover:bg-gray-100 transition shadow-md">
            Connect to Buyers
        </button>
    </nav>

    <!-- HERO SECTION -->
    <header class="relative w-full h-[90vh] bg-cover bg-center flex items-end pb-20 px-8 md:px-16" 
            style="background-image: url('https://images.unsplash.com/photo-1620200423727-8127f75d7f53?q=80&w=1740&auto=format&fit=crop');">
        
        <!-- Dark Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10"></div>

        <!-- Hero Content -->
        <div class="relative z-10 w-full max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-end gap-8">
            <!-- Left Side -->
            <div class="max-w-3xl">
                <h1 class="text-5xl md:text-7xl font-bold text-white leading-tight mb-6">
                    Direct Markets & <br /> Smart Weather
                </h1>
                <p class="text-lg text-gray-200 mb-8 max-w-xl font-medium">
                    Bridge the gap to urban centers to reduce post-harvest waste and anticipate environmental shifts to protect your yields.
                </p>
                <div class="flex flex-wrap gap-4">
                    <button class="bg-white text-gray-900 px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition shadow-lg">
                        Open Marketplace
                    </button>
                    <button class="bg-transparent border border-white text-white px-8 py-3 rounded-full font-semibold hover:bg-white/10 transition">
                        View Weather Radar
                    </button>
                </div>
            </div>

            <!-- Right Side: Floating Card -->
            <div class="bg-white p-4 rounded-2xl shadow-2xl flex items-center gap-4 min-w-[320px]">
                <div class="w-20 h-20 bg-green-100 flex items-center justify-center text-4xl rounded-xl">
                    🏙️
                </div>
                <div class="flex-1">
                    <h4 class="font-bold text-gray-900">Active Urban Buyers</h4>
                    <p class="text-xs text-gray-500 mt-1">120+ Local Restaurants</p>
                    <p class="text-xs text-gray-500">Ready to buy surplus</p>
                </div>
                <button class="bg-green-700 text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-green-800 transition">
                    ↗
                </button>
            </div>
        </div>
    </header>

    <!-- NEW SECTION 1: ABOUT US (Innovating Agriculture) -->
    <section class="max-w-7xl mx-auto px-8 md:px-16 pt-24 pb-12">
        
        <!-- Header -->
        <div class="mb-12">
            <div class="flex items-center gap-2 font-bold text-gray-900 mb-4 text-sm">
                <span class="text-theme-lime text-lg">🌱</span> About Us
            </div>
            <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight max-w-2xl">
                Innovating Agriculture, <br/> Sustaining Our Future
            </h2>
        </div>

        <!-- 4 Columns Features -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-16">
            <!-- Col 1 -->
            <div>
                <div class="text-4xl mb-4 text-theme-lime">🌾</div>
                <h3 class="font-bold text-gray-900 text-lg mb-2">Market Access</h3>
                <p class="text-sm text-gray-500 leading-relaxed">Connecting rural producers directly with urban buyers to reduce food waste.</p>
            </div>
            <!-- Col 2 -->
            <div>
                <div class="text-4xl mb-4 text-theme-lime">🌦️</div>
                <h3 class="font-bold text-gray-900 text-lg mb-2">Weather Analytics</h3>
                <p class="text-sm text-gray-500 leading-relaxed">Actionable insights to help farmers anticipate and manage environmental shifts.</p>
            </div>
            <!-- Col 3 -->
            <div>
                <div class="text-4xl mb-4 text-theme-lime">🚜</div>
                <h3 class="font-bold text-gray-900 text-lg mb-2">Yield Optimization</h3>
                <p class="text-sm text-gray-500 leading-relaxed">Smart tools and data-driven methods to secure and improve total crop yields.</p>
            </div>
            <!-- Col 4 -->
            <div>
                <div class="text-4xl mb-4 text-theme-lime">📈</div>
                <h3 class="font-bold text-gray-900 text-lg mb-2">Financial Growth</h3>
                <p class="text-sm text-gray-500 leading-relaxed">Empowering farmers with better records for financial inclusion and credit access.</p>
            </div>
        </div>

        <!-- 2 Images Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Image Left -->
            <div class="rounded-3xl overflow-hidden h-72 md:h-96">
                <img src="https://images.unsplash.com/photo-1592982537447-7440770cbfc9?q=80&w=1000&auto=format&fit=crop" alt="Tractor in field" class="w-full h-full object-cover">
            </div>
            <!-- Image Right with Overlay -->
            <div class="rounded-3xl overflow-hidden h-72 md:h-96 relative group">
                <img src="https://images.unsplash.com/photo-1589923188900-85dae523342b?q=80&w=1000&auto=format&fit=crop" alt="Farmer" class="w-full h-full object-cover">
                <!-- Overlay gradient -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                <!-- Content overlay -->
                <div class="absolute bottom-0 left-0 w-full p-6 md:p-8 flex justify-between items-end">
                    <p class="text-white font-medium max-w-[200px] text-sm md:text-base leading-relaxed">
                        Agriculture nurtures life through organic growth, sustainable farming.
                    </p>
                    <button class="bg-theme-lime hover-bg-theme-lime text-gray-900 font-bold px-6 py-2.5 rounded-full transition text-sm flex items-center gap-2 shadow-lg">
                        About Us ↗
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- NEW SECTION 2: SUSTAINABLE FARMING (Cream Background) -->
    <section class="bg-cream w-full py-24">
        <div class="max-w-7xl mx-auto px-8 md:px-16">
            
            <!-- Header Row -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20 items-end">
                <div>
                    <div class="flex items-center gap-2 font-bold text-gray-900 mb-4 text-sm">
                        <span class="text-theme-lime text-lg">🌱</span> Sustainable Farming
                    </div>
                    <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
                        Cultivating Excellence in <br/> Every Green Field
                    </h2>
                </div>
                <div>
                    <p class="text-gray-500 leading-relaxed text-sm md:text-base max-w-md">
                        We are committed to bridging the gap between local producers and urban markets, ensuring food reaches consumers efficiently while it is still fresh and nutritious.
                    </p>
                </div>
            </div>

            <!-- Staggered Stats Cards -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative">
                
                <!-- Floating Button (Positioned above middle card) -->
                <!-- <div class="hidden md:flex absolute -top-14 left-1/2 transform -translate-x-1/2 z-10">
                    <button class="bg-theme-lime hover-bg-theme-lime text-gray-900 font-bold px-8 py-3 rounded-full transition text-sm shadow-lg">
                        Get In Touch ↗
                    </button>
                </div> -->

                <!-- Card 1 (Left) -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col justify-end h-80 md:mt-12 overflow-hidden relative group">
                    <img src="https://images.unsplash.com/photo-1601493700631-2b16ec4b4716?q=80&w=600&auto=format&fit=crop" alt="Corn" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-105 transition duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-white via-white/80 to-transparent"></div>
                    <div class="relative z-10">
                        <h3 class="text-6xl font-black text-gray-900 tracking-tighter mb-1">80%</h3>
                        <p class="text-gray-900 font-bold text-lg">Efficiency</p>
                    </div>
                </div>

                <!-- Card 2 (Center - Shifted Up) -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col justify-end h-80 md:-mt-4 overflow-hidden relative group">
                    <img src="https://images.unsplash.com/photo-1574323347407-f5e1ad6d020b?q=80&w=600&auto=format&fit=crop" alt="Seeds" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-105 transition duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-white via-white/80 to-transparent"></div>
                    <div class="relative z-10">
                        <h3 class="text-6xl font-black text-gray-900 tracking-tighter mb-1">98%</h3>
                        <p class="text-gray-900 font-bold text-lg">Increase in Yields</p>
                    </div>
                </div>

                <!-- Card 3 (Right) -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col justify-end h-80 md:mt-12 overflow-hidden relative group">
                    <img src="https://images.unsplash.com/photo-1557844352-761f2565b576?q=80&w=600&auto=format&fit=crop" alt="Plant" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-105 transition duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-white via-white/80 to-transparent"></div>
                    <div class="relative z-10">
                        <h3 class="text-6xl font-black text-gray-900 tracking-tighter mb-1">50%</h3>
                        <p class="text-gray-900 font-bold text-lg">Farm Growth</p>
                    </div>
                </div>

            </div>
        </div>
    </section>
</body>
</html>