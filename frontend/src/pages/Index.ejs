<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.judul || 'AgriHub - Market & Weather' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .text-theme-lime { color: #849f2b; }
        .bg-theme-lime { background-color: #D6E44E; }
        .hover-bg-theme-lime:hover { background-color: #c4d142; }
        .bg-cream { background-color: #FCFBF6; }
    </style>
</head>
<body class="bg-[#F6F7F6] text-gray-900 antialiased overflow-x-hidden">

    <nav class="absolute top-0 left-0 w-full z-50 px-8 py-6 flex justify-between items-center text-white">
        <div class="text-2xl font-bold text-green-800 tracking-tight">AgriHub</div>
        <div class="hidden md:flex space-x-8 font-medium text-sm text-white">
            <a href="#" class="hover:text-green-300 transition border-b-2 border-white pb-1">Home</a>
            <a href="/marketplace" class="hover:text-green-300 transition">Marketplace</a>
            <!-- <a href="/dashboard" class="hover:text-green-300 transition">Dashboard</a> -->
        </div>
        <button class="bg-white text-gray-900 px-6 py-2 rounded-full text-sm font-semibold hover:bg-gray-100 transition shadow-md">Connect to Buyers</button>
    </nav>

    <!-- HERO SECTION -->
    <header class="relative w-full h-[90vh] bg-cover bg-center flex items-end pb-20 px-8 md:px-16" 
            style="background-image: url('https://images.unsplash.com/photo-1620200423727-8127f75d7f53?q=80&w=1740&auto=format&fit=crop');">
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10"></div>
        <div class="relative z-10 w-full max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-end gap-8">
            <div class="max-w-3xl">
                <h1 class="text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Direct Markets & <br /> Smart Weather</h1>
                <p class="text-lg text-gray-200 mb-8 max-w-xl font-medium">Bridge the gap to urban centers to reduce post-harvest waste and anticipate environmental shifts.</p>
                <div class="flex flex-wrap gap-4">
                    <a href="/marketplace" class="bg-white text-gray-900 px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition shadow-lg">Open Marketplace</a>
                </div>
            </div>

            <!-- Floating Card (Dynamic Count) -->
            <div class="bg-white p-4 rounded-2xl shadow-2xl flex items-center gap-4 min-w-[320px]">
                <div class="w-20 h-20 bg-green-100 flex items-center justify-center text-4xl rounded-xl">👨‍🌾</div>
                <div class="flex-1">
                    <h4 class="font-bold text-gray-900">Active Farmers</h4>
                    <p id="hero-farmer-count" class="text-xs text-gray-500 mt-1 font-bold">Loading data...</p>
                    <p class="text-xs text-gray-500">Ready to supply surplus</p>
                </div>
            </div>
        </div>
    </header>

    <!-- SECTION 1: ABOUT US -->
    <section class="max-w-7xl mx-auto px-8 md:px-16 pt-24 pb-12">
        <div class="mb-12">
            <div class="flex items-center gap-2 font-bold text-gray-900 mb-4 text-sm">
                <span class="text-theme-lime text-lg">🌱</span> About Us
            </div>
            <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight max-w-2xl">Innovating Agriculture, <br/> Sustaining Our Future</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-16">
            <div><div class="text-4xl mb-4 text-theme-lime">🌾</div><h3 class="font-bold text-gray-900 text-lg mb-2">Market Access</h3><p class="text-sm text-gray-500">Connecting rural producers directly with urban buyers.</p></div>
            <div><div class="text-4xl mb-4 text-theme-lime">🌦️</div><h3 class="font-bold text-gray-900 text-lg mb-2">Weather Analytics</h3><p class="text-sm text-gray-500">Actionable insights to manage environmental shifts.</p></div>
            <div><div class="text-4xl mb-4 text-theme-lime">🚜</div><h3 class="font-bold text-gray-900 text-lg mb-2">Yield Optimization</h3><p class="text-sm text-gray-500">Smart tools to secure total crop yields.</p></div>
            <div><div class="text-4xl mb-4 text-theme-lime">📈</div><h3 class="font-bold text-gray-900 text-lg mb-2">Financial Growth</h3><p class="text-sm text-gray-500">Empowering farmers with better records.</p></div>
        </div>
    </section>

    <!-- SECTION 2: SUSTAINABLE FARMING -->
    <section class="bg-cream w-full py-24">
        <div class="max-w-7xl mx-auto px-8 md:px-16">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20 items-end">
                <div>
                    <div class="flex items-center gap-2 font-bold text-gray-900 mb-4 text-sm"><span class="text-theme-lime text-lg">🌱</span> Sustainable Farming</div>
                    <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">Cultivating Excellence in <br/> Every Green Field</h2>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative">
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col justify-end h-80 md:mt-12 overflow-hidden relative group">
                    <img src="https://images.unsplash.com/photo-1601493700631-2b16ec4b4716?q=80&w=600&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-105 transition duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-white via-white/80 to-transparent"></div>
                    <div class="relative z-10"><h3 class="text-6xl font-black text-gray-900 tracking-tighter mb-1">80%</h3><p class="text-gray-900 font-bold text-lg">Efficiency</p></div>
                </div>
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col justify-end h-80 md:-mt-4 overflow-hidden relative group">
                    <img src="https://images.unsplash.com/photo-1574323347407-f5e1ad6d020b?q=80&w=600&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-105 transition duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-white via-white/80 to-transparent"></div>
                    <div class="relative z-10"><h3 class="text-6xl font-black text-gray-900 tracking-tighter mb-1">98%</h3><p class="text-gray-900 font-bold text-lg">Increase in Yields</p></div>
                </div>
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col justify-end h-80 md:mt-12 overflow-hidden relative group">
                    <img src="https://images.unsplash.com/photo-1557844352-761f2565b576?q=80&w=600&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-105 transition duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-white via-white/80 to-transparent"></div>
                    <div class="relative z-10"><h3 class="text-6xl font-black text-gray-900 tracking-tighter mb-1">50%</h3><p class="text-gray-900 font-bold text-lg">Farm Growth</p></div>
                </div>
            </div>
        </div>
    </section>

    <!-- FETCH SCRIPT FOR LANDING PAGE -->
    <script>
        document.addEventListener("DOMContentLoaded", async () => {
            try {
                // Ambil info dari API Dashboard
                const res = await fetch('/api/dashboard');
                const data = await res.json();
                
                // Tampilkan total petani yang terdaftar di database
                const farmerCount = data.totalFarmers || 0;
                document.getElementById('hero-farmer-count').innerText = `${farmerCount}+ Registered Partners`;
            } catch (err) {
                document.getElementById('hero-farmer-count').innerText = "Partners Network";
            }
        });
    </script>
</body>
</html>