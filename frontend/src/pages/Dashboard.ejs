<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.judul || 'AgriHub - Farmer Dashboard' %></title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-[#F6F7F6] text-gray-900 antialiased overflow-x-hidden min-h-screen flex flex-col">

    <!-- NAVBAR (Dashboard Active) -->
    <nav class="absolute top-0 left-0 w-full z-50 px-8 py-6 flex justify-between items-center text-white">
    <!-- <nav class="bg-[#1A3626] w-full z-50 px-8 py-4 flex justify-between items-center text-white shadow-md"> -->
        <div class="text-2xl font-bold text-white tracking-tight">AgriHub</div>
        
        <div class="hidden md:flex space-x-8 font-medium text-sm text-gray-300">
            <a href="/" class="text-white border-b-2 border-green-400 pb-1">Home</a>
            <a href="/marketplace" class="hover:text-white transition">Marketplace</a>
            <a href="#" class="hover:text-white transition">Weather Alerts</a>
            <a href="#" class="hover:text-white transition">Reports</a>
        </div>

        <div class="flex items-center gap-4">
            <span class="text-sm hidden md:block">📍 Tangerang, Banten</span>
            <div class="w-10 h-10 bg-green-700 rounded-full flex items-center justify-center font-bold shadow-inner">
                👨‍🌾
            </div>
        </div>
    </nav>

    <!-- HEADER / WELCOME -->
    <header class="w-full bg-white border-b border-gray-200 pt-10 pb-8 px-8 md:px-16">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-end gap-6">
            <div>
                <p class="text-sm font-semibold text-green-600 mb-1">Kamis, 16 Juli 2026</p>
                <h1 class="text-3xl md:text-4xl font-bold text-gray-900">
                    Halo, <%= locals.petani || 'Pak Budi' %> 👋
                </h1>
                <p class="text-gray-500 mt-2">Berikut adalah ringkasan operasional ladang dan gudangmu hari ini.</p>
            </div>
            <div class="flex gap-3">
                <button class="bg-gray-100 text-gray-700 px-6 py-2 rounded-full font-semibold hover:bg-gray-200 transition shadow-sm text-sm">
                    Unduh Laporan Keuangan
                </button>
            </div>
        </div>
    </header>

    <!-- MAIN DASHBOARD CONTENT -->
    <main class="max-w-7xl mx-auto w-full px-8 md:px-16 py-10 flex-1 space-y-8">
        
        <!-- KPI CARDS (Financial & Inventory Quick Stats) -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Revenue -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex items-center gap-5">
                <div class="w-14 h-14 bg-green-50 rounded-full flex items-center justify-center text-2xl">💰</div>
                <div>
                    <p class="text-sm text-gray-500 font-medium">Pendapatan Bulan Ini</p>
                    <h3 class="text-2xl font-bold text-gray-900">Rp 4.500.000</h3>
                </div>
            </div>
            <!-- Active Stock -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex items-center gap-5">
                <div class="w-14 h-14 bg-blue-50 rounded-full flex items-center justify-center text-2xl">📦</div>
                <div>
                    <p class="text-sm text-gray-500 font-medium">Total Stok Gudang</p>
                    <h3 class="text-2xl font-bold text-gray-900">145 Kg</h3>
                </div>
            </div>
            <!-- At Risk -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-red-100 flex items-center gap-5">
                <div class="w-14 h-14 bg-red-50 rounded-full flex items-center justify-center text-2xl">⚠️</div>
                <div>
                    <p class="text-sm text-gray-500 font-medium">Potensi Limbah (Segera Jual)</p>
                    <h3 class="text-2xl font-bold text-red-600">15 Kg</h3>
                </div>
            </div>
        </div>

        <!-- TWO COLUMN LAYOUT -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            
            <!-- LEFT COLUMN (Weather & Market Intelligence) -->
            <div class="md:col-span-2 space-y-8">
                
                <!-- Smart Weather Action -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 border-l-4 border-l-blue-500">
                    <div class="flex items-center gap-2 mb-4">
                        <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                        <h3 class="font-bold text-gray-900 text-lg">Prediksi Cuaca & Tindakan</h3>
                    </div>
                    <div class="flex flex-col md:flex-row items-center gap-6 bg-blue-50/50 p-5 rounded-2xl border border-blue-100">
                        <div class="text-center md:text-left min-w-[120px] border-b md:border-b-0 md:border-r border-blue-200 pb-4 md:pb-0 md:pr-6">
                            <div class="text-5xl mb-2">⛈️</div>
                            <p class="font-bold text-blue-900 text-xl">26°C</p>
                            <p class="text-xs text-blue-700 font-medium uppercase tracking-wider">Hujan Petir</p>
                            <p class="text-xs text-gray-500 mt-1">Besok, 14:00</p>
                        </div>
                        <div>
                            <h4 class="font-bold text-blue-900 mb-1 flex items-center gap-2">
                                💡 Spekulasi AI
                            </h4>
                            <p class="text-blue-800 text-sm leading-relaxed">
                                Curah hujan tinggi terdeteksi di area Tangerang besok siang. <b>Tugas prioritas:</b> Panen Sawi Hijau hari ini untuk mencegah pembusukan akar. Tunda penyemprotan pestisida cair karena akan luntur terbawa air hujan.
                            </p>
                            <button class="mt-3 bg-blue-600 text-white px-4 py-2 rounded-full text-xs font-semibold hover:bg-blue-700 transition">
                                + Tambahkan ke Jadwal Pekerja
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Market Intelligence (Barang Langka) -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 border-l-4 border-l-purple-500">
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center gap-2">
                            <span class="w-2 h-2 bg-purple-500 rounded-full animate-pulse"></span>
                            <h3 class="font-bold text-gray-900 text-lg">Radar Permintaan Kota</h3>
                        </div>
                        <span class="text-xs font-bold text-purple-600 bg-purple-100 px-3 py-1 rounded-full">Live Data</span>
                    </div>
                    <div class="space-y-4">
                        <!-- Insight 1 -->
                        <div class="flex items-start gap-4 p-4 rounded-2xl bg-gray-50 border border-gray-100 hover:border-purple-200 transition">
                            <div class="text-3xl">🌶️</div>
                            <div class="flex-1">
                                <h4 class="font-bold text-gray-900">Cabai Rawit Merah</h4>
                                <p class="text-sm text-gray-500 mt-1">Stok di pasar induk menipis. 4 restoran mencari pasokan darurat hari ini.</p>
                            </div>
                            <div class="text-right">
                                <p class="text-xs text-gray-400">Tren Harga</p>
                                <p class="font-bold text-green-600">▲ +15%</p>
                            </div>
                        </div>
                        <!-- Insight 2 -->
                        <div class="flex items-start gap-4 p-4 rounded-2xl bg-gray-50 border border-gray-100 hover:border-purple-200 transition">
                            <div class="text-3xl">🧅</div>
                            <div class="flex-1">
                                <h4 class="font-bold text-gray-900">Bawang Merah</h4>
                                <p class="text-sm text-gray-500 mt-1">Permintaan stabil tinggi menjelang akhir pekan. Cocok untuk segera dipanen jika sudah matang.</p>
                            </div>
                            <div class="text-right">
                                <p class="text-xs text-gray-400">Tren Harga</p>
                                <p class="font-bold text-green-600">▲ +5%</p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- RIGHT COLUMN (Inventory / Gudang) -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col">
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                        <h3 class="font-bold text-gray-900 text-lg">Kondisi Gudang</h3>
                    </div>
                    <button class="text-gray-400 hover:text-green-600 transition text-sm font-medium">Lihat Semua</button>
                </div>

                <div class="space-y-5 flex-1">
                    <!-- Item Gudang 1 -->
                    <div class="flex justify-between items-center">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center text-lg">🍅</div>
                            <div>
                                <h4 class="font-bold text-sm text-gray-900">Tomat Cherry</h4>
                                <p class="text-xs text-green-600 font-medium">Kondisi Segar</p>
                            </div>
                        </div>
                        <p class="font-bold text-gray-900">50 Kg</p>
                    </div>

                    <!-- Item Gudang 2 (Warning) -->
                    <div class="flex justify-between items-center p-3 -mx-3 bg-red-50 rounded-xl border border-red-100">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-lg">🥬</div>
                            <div>
                                <h4 class="font-bold text-sm text-gray-900">Sawi Putih</h4>
                                <p class="text-xs text-red-600 font-medium">Mendekati Busuk (H-1)</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="font-bold text-gray-900">15 Kg</p>
                            <a href="/marketplace" class="text-[10px] bg-red-600 text-white px-2 py-1 rounded font-bold hover:bg-red-700 transition">Diskon Sekarang</a>
                        </div>
                    </div>

                    <!-- Item Gudang 3 -->
                    <div class="flex justify-between items-center">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center text-lg">🧅</div>
                            <div>
                                <h4 class="font-bold text-sm text-gray-900">Bawang Merah</h4>
                                <p class="text-xs text-green-600 font-medium">Kondisi Kering (Aman)</p>
                            </div>
                        </div>
                        <p class="font-bold text-gray-900">80 Kg</p>
                    </div>
                </div>

                <button class="mt-6 w-full bg-green-700 text-white py-3 rounded-full text-sm font-semibold hover:bg-green-800 transition shadow-md">
                    + Input Panen Baru
                </button>
            </div>

        </div>
    </main>

</body>
</html>