<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.judul || 'AgriHub - Farmer Dashboard' %></title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #F9FAFB; }
        .theme-green { color: #165B33; }
        .bg-theme-green { background-color: #165B33; }
        .hover-bg-theme-green:hover { background-color: #0f4224; }
        .bg-card-blue { background-color: #F0FAFB; }
        .bg-card-green { background-color: #F4FBF0; }
        .bg-weather-main { background-color: #DDF3E4; }
        .bg-weather-sub { background-color: #F7F9F7; }
        /* Styling untuk dropdown status */
        select.status-dropdown { appearance: none; padding-right: 1.5rem; background-image: url('data:image/svg+xml;utf8,<svg fill="%23333" height="24" viewBox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg"><path d="M7 10l5 5 5-5z"/><path d="M0 0h24v24H0z" fill="none"/></svg>'); background-repeat: no-repeat; background-position-x: 95%; background-position-y: 50%; }
    </style>
</head>
<body class="text-gray-900 antialiased overflow-x-hidden min-h-screen flex flex-col">

    <!-- WADAH UTAMA (NAVBAR SELALU MUNCUL) -->
    <div class="relative w-full bg-cover bg-center shadow-md" style="background-image: url('https://images.unsplash.com/photo-1592982537447-7440770cbfc9?q=80&w=2000&auto=format&fit=crop');">
        <div class="absolute inset-0 bg-[#1A3626]/80 backdrop-blur-sm"></div>
        <nav class="relative z-10 w-full px-8 py-6 flex justify-between items-center text-white border-b border-white/10">
            <div class="text-2xl font-bold tracking-tight">AgriHub <span class="text-xs bg-green-600 px-2 py-1 rounded text-white ml-2">ADMIN</span></div>
            <div class="hidden md:flex space-x-8 font-medium text-sm text-gray-300">
                <a href="/" class="hover:text-white transition">Home</a>
                <a href="/marketplace" class="hover:text-white transition">Marketplace</a>
                <a href="/dashboard" class="text-white border-b-2 border-green-400 pb-1">Dashboard</a>
            </div>
            <div id="auth-nav-ui" class="flex items-center gap-4"></div>
        </nav>
        <header id="welcome-header" class="hidden relative z-10 w-full pt-10 pb-16 px-8 md:px-16 text-white">
            <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-end gap-6">
                <div>
                    <p id="current-date" class="text-sm font-bold text-green-300 mb-2">Memuat tanggal...</p>
                    <h1 class="text-3xl md:text-4xl font-bold">Halo, <span id="farmer-name-display">Juragan</span> 👋</h1>
                    <p class="text-gray-300 mt-2 text-lg max-w-xl">Pusat kendali operasional ladang dan stok panen.</p>
                </div>
            </div>
        </header>
        <div id="login-header-space" class="relative z-10 w-full pt-10 pb-24"></div>
    </div>

    <!-- HALAMAN LOGIN ADMIN (SIMULASI) -->
    <main id="login-main" class="max-w-5xl mx-auto w-full px-4 md:px-8 relative z-20 -mt-16 mb-12">
        <div class="bg-white w-full md:h-[550px] rounded-3xl shadow-2xl flex flex-col md:flex-row overflow-hidden relative">
            <div class="w-full md:w-1/2 p-10 md:p-14 flex flex-col justify-center bg-white">
                <div class="flex gap-3 mb-8">
                    <div class="bg-white border border-gray-200 text-[10px] font-bold px-3 py-1.5 rounded-md flex items-center gap-1 shadow-sm"><span class="text-blue-500 text-sm">▶</span> Google Play</div>
                    <div class="bg-black border border-black text-white text-[10px] font-bold px-3 py-1.5 rounded-md flex items-center gap-1 shadow-sm"><span class="text-sm">🍏</span> App Store</div>
                </div>
                <p class="text-gray-500 font-medium mb-1">Welcome Admin</p>
                <h1 class="text-4xl font-black text-gray-900 mb-8 tracking-tight">Log In</h1>
                <form id="form-fake-login" onsubmit="processFarmerLogin(event)">
                    <div class="mb-5">
                        <label class="block text-xs font-bold text-gray-700 mb-2">Your Email</label>
                        <input type="email" id="farmer-email" required class="w-full border border-gray-200 rounded-lg p-3 outline-none focus:border-[#165B33] transition" placeholder="admin@agrihub.com">
                    </div>
                    <div class="mb-2">
                        <label class="block text-xs font-bold text-gray-700 mb-2">Password</label>
                        <div class="relative"><input type="password" id="farmer-password" required class="w-full border border-gray-200 rounded-lg p-3 outline-none focus:border-[#165B33] transition" placeholder="Password"><span class="absolute right-4 top-3 text-gray-400 cursor-pointer">👁️</span></div>
                    </div>
                    <div class="text-right mb-6"><a href="#" class="text-[11px] text-blue-500 hover:underline font-medium">Lupa kata sandi ?</a></div>
                    <button type="submit" id="btn-farmer-login" class="w-full bg-[#165B33] text-white font-bold py-3.5 rounded-lg hover:bg-[#0f4224] transition shadow-md">Log In Dashboard</button>
                </form>
            </div>
            <div class="hidden md:flex w-1/2 bg-[#165B33] flex-col items-center justify-center p-12 text-center relative overflow-hidden">
                <div class="absolute -top-16 -left-16 w-64 h-64 bg-green-500/20 rounded-full blur-3xl"></div>
                <div class="absolute -bottom-16 -right-16 w-64 h-64 bg-green-900/40 rounded-full blur-3xl"></div>
                <div class="absolute top-8 right-8 text-white text-right"><h2 class="text-2xl font-bold tracking-tight">AgriHub</h2><p class="text-xs text-green-200 font-medium">( Farmer Admin )</p></div>
                <img src="https://cdni.iconscout.com/illustration/premium/thumb/farmers-working-in-farm-4328221-3603126.png" class="w-4/5 object-contain mb-8 z-10 relative drop-shadow-2xl filter brightness-110">
                <h3 class="text-3xl font-bold text-white mb-3 z-10 relative">Manage your farm easily</h3>
                <p class="text-green-100 text-sm z-10 relative px-4 max-w-sm leading-relaxed">Control your inventory, monitor weather, and check incoming orders efficiently in one place!</p>
            </div>
        </div>
    </main>

    <!-- WADAH KONTEN DASHBOARD -->
    <main id="dashboard-main" class="hidden max-w-7xl mx-auto w-full px-4 md:px-8 py-8 relative z-20 bg-white rounded-t-3xl -mt-6 shadow-xl mb-12">
        <div class="flex flex-col lg:flex-row gap-8 w-full">
            <div class="lg:w-2/3 flex flex-col gap-8">
                <!-- MANAGE YOUR FARM -->
                <div>
                    <div class="flex justify-between items-center mb-4"><h2 class="text-lg font-bold text-gray-800">Manage your farm</h2></div>
                    <div class="relative w-full h-56 rounded-3xl overflow-hidden shadow-sm group">
                        <img src="https://images.unsplash.com/photo-1595841696677-6489ff3f8cd1?q=80&w=1000&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
                        <div class="absolute inset-0 bg-gradient-to-r from-black/60 to-transparent"></div>
                        <div class="absolute inset-0 p-8 flex flex-col justify-center">
                            <h3 class="text-2xl font-bold text-white mb-2">Musim Panen Tiba!</h3>
                            <p class="text-white/80 text-sm mb-4 max-w-sm">Perbarui inventaris gudang Anda agar restoran kota bisa langsung memesan hasil bumi Anda.</p>
                            <button onclick="openProductModal()" class="bg-white text-green-700 w-max px-6 py-2.5 rounded-full font-bold shadow-md hover:bg-green-50 transition text-sm">+ Tambah Hasil Panen (CRUD)</button>
                        </div>
                    </div>
                </div>

                <!-- INVENTORY MANAGEMENT (DENGAN COUNTDOWN EXPIRED) -->
                <div>
                    <h2 class="text-lg font-bold text-gray-800 mb-4">Live Inventory (Database)</h2>
                    <div class="bg-white border border-gray-100 rounded-3xl shadow-sm overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead>
                                    <tr class="bg-gray-50 border-b border-gray-100 text-sm text-gray-500">
                                        <th class="p-4 font-semibold">Nama Produk</th>
                                        <th class="p-4 font-semibold">Kondisi (Expired)</th>
                                        <th class="p-4 font-semibold">Stok & Harga</th>
                                        <th class="p-4 font-semibold text-right">Aksi</th>
                                    </tr>
                                </thead>
                                <tbody id="product-table-body" class="text-sm text-gray-700">
                                    <tr><td colspan="4" class="p-4 text-center text-gray-400">Memuat data dari database...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ORDER HISTORY (DENGAN TOMBOL UPDATE STATUS) -->
                <div class="mt-8">
                    <h2 class="text-lg font-bold text-gray-800 mb-4">Riwayat Pesanan & Pengiriman</h2>
                    <div class="bg-white border border-gray-100 rounded-3xl shadow-sm overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead>
                                    <tr class="bg-gray-50 border-b border-gray-100 text-sm text-gray-500">
                                        <th class="p-4 font-semibold">Tgl / Pembeli</th>
                                        <th class="p-4 font-semibold">Detail Item</th>
                                        <th class="p-4 font-semibold">Total Pendapatan</th>
                                        <th class="p-4 font-semibold text-right">Status (Klik untuk ubah)</th>
                                    </tr>
                                </thead>
                                <tbody id="orders-table-body" class="text-sm text-gray-700">
                                    <tr><td colspan="4" class="p-4 text-center text-gray-400">Memuat riwayat pesanan...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- KOLOM KANAN -->
            <div class="lg:w-1/3 flex flex-col gap-8 w-full">
                <!-- WEATHER FORECAST -->
                <div>
                    <div class="flex justify-between items-center mb-4"><h2 class="text-lg font-bold text-gray-800">Live Weather</h2></div>
                    <div class="bg-weather-main rounded-3xl p-6 shadow-sm flex items-center justify-between mb-4">
                        <div>
                            <p class="font-bold text-gray-800 mb-1">Hari Ini</p>
                            <div class="flex items-end gap-1">
                                <h3 id="weather-current-temp" class="text-4xl font-black text-gray-900">--°</h3>
                            </div>
                            <p id="weather-current-desc" class="text-xs text-gray-600 mt-1 font-medium">Memuat satelit...</p>
                        </div>
                        <div id="weather-current-icon" class="text-6xl drop-shadow-md animate-pulse">⏳</div>
                    </div>
                </div>

                <!-- ASSET ESTIMATION -->
                <div class="bg-weather-main rounded-3xl p-6 shadow-sm flex flex-col justify-between mt-auto">
                    <h3 class="font-bold text-gray-800 mb-4">Total Stock Value</h3>
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-sm text-gray-600">Total Produk Gudang</span><span id="asset-count" class="text-sm font-bold">0 Item</span>
                    </div>
                    <hr class="border-green-200 mb-4">
                    <div class="flex justify-between items-end">
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Total Asset Estimation</p>
                            <h3 id="total-asset-value" class="text-2xl lg:text-3xl font-black text-gray-900">Rp 0</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- TOAST NOTIFICATION -->
    <div id="toast-notification" class="fixed bottom-6 right-6 bg-white border-l-4 border-theme-green shadow-2xl rounded-lg p-4 z-[200] transform translate-y-32 opacity-0 transition-all duration-500 flex items-center gap-3"><span id="toast-message" class="text-gray-800 font-semibold text-sm">Notifikasi</span></div>

    <!-- MODAL CRUD PRODUCT -->
    <div id="crud-modal" class="fixed inset-0 bg-black/60 z-[100] hidden flex items-center justify-center backdrop-blur-sm px-4">
        <div class="bg-white rounded-3xl p-8 max-w-lg w-full shadow-2xl relative">
            <h2 id="modal-title" class="text-2xl font-bold text-gray-900 mb-1">Tambah Panen Baru</h2>
            <p class="text-sm text-gray-500 mb-6">Masa kedaluwarsa akan otomatis diset 7 Hari sejak diinput.</p>
            <form id="product-form" onsubmit="handleProductSubmit(event)">
                <input type="hidden" id="prod-id">
                <div class="mb-4">
                    <label class="block text-sm font-bold text-gray-700 mb-1">Nama Produk</label>
                    <input type="text" id="prod-name" required class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:border-[#165B33]">
                </div>
                <div class="grid grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Stok (Kg)</label>
                        <input type="number" id="prod-stock" required class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:border-[#165B33]">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Harga (Rp/Kg)</label>
                        <input type="number" id="prod-price" required class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:border-[#165B33]">
                    </div>
                </div>
                <div class="mb-6">
                    <label class="block text-sm font-bold text-gray-700 mb-1">Kategori</label>
                    <select id="prod-category" required class="w-full border border-gray-300 rounded-lg p-3 outline-none focus:border-[#165B33]">
                        <option value="Vegetables">Vegetables</option>
                        <option value="Fruits">Fruits</option>
                        <option value="Herbs & Spices">Herbs & Spices</option>
                    </select>
                </div>
                <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                    <button type="button" onclick="closeProductModal()" class="text-gray-500 font-bold px-4 py-2 rounded-lg">Batal</button>
                    <button type="submit" id="btn-save-product" class="bg-[#165B33] text-white font-bold px-6 py-2 rounded-lg">Simpan Data</button>
                </div>
            </form>
        </div>
    </div>

    <!-- LOGIC JAVASCRIPT -->
    <script>
        document.getElementById('current-date').innerText = new Date().toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

        function showToast(message, isError = false) {
            const toast = document.getElementById('toast-notification');
            document.getElementById('toast-message').innerText = message;
            if(isError) toast.classList.replace('border-theme-green', 'border-red-500');
            else toast.classList.replace('border-red-500', 'border-theme-green');
            toast.classList.remove('translate-y-32', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');
            setTimeout(() => {
                toast.classList.remove('translate-y-0', 'opacity-100');
                toast.classList.add('translate-y-32', 'opacity-0');
            }, 3000);
        }

        document.addEventListener("DOMContentLoaded", () => { checkAdminAuth(); });

        function checkAdminAuth() {
            const adminData = localStorage.getItem('agrihub_admin_auth');
            const authNavUI = document.getElementById('auth-nav-ui');

            if (adminData) {
                const name = JSON.parse(adminData).name;
                document.getElementById('welcome-header').classList.remove('hidden');
                document.getElementById('dashboard-main').classList.remove('hidden');
                document.getElementById('dashboard-main').classList.add('flex');
                document.getElementById('login-header-space').classList.add('hidden');
                document.getElementById('login-main').classList.add('hidden');
                document.getElementById('farmer-name-display').innerText = name;
                
                authNavUI.innerHTML = `<div class="text-right"><p class="text-sm font-bold text-white">${name}</p><button onclick="farmerLogout()" class="text-xs text-red-300 font-medium hover:text-red-100 transition">Logout Keluar</button></div><div class="w-10 h-10 bg-[#165B33] rounded-full flex items-center justify-center font-bold shadow-inner text-xl border-2 border-white/20">👨‍🌾</div>`;
                
                loadProducts(); loadOrdersHistory(); loadWeatherAPI();
            } else {
                document.getElementById('welcome-header').classList.add('hidden');
                document.getElementById('dashboard-main').classList.add('hidden');
                document.getElementById('dashboard-main').classList.remove('flex');
                document.getElementById('login-header-space').classList.remove('hidden');
                document.getElementById('login-main').classList.remove('hidden');
                authNavUI.innerHTML = `<div class="text-right"><p class="text-sm font-bold text-gray-300">Guest</p></div><div class="w-10 h-10 bg-gray-500/50 rounded-full flex items-center justify-center font-bold shadow-inner text-xl border-2 border-white/20">🔒</div>`;
            }
        }

        async function processFarmerLogin(e) {
            e.preventDefault();
            const email = document.getElementById('farmer-email').value;
            const password = document.getElementById('farmer-password').value;
            const btn = document.getElementById('btn-farmer-login');
            btn.innerText = "Mengautentikasi..."; btn.disabled = true;

            try {
                const response = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });
                const data = await response.json();

                if (response.ok) {
                    if (data.user && data.user.role === 'admin') {
                        localStorage.setItem('agrihub_admin_auth', JSON.stringify({ name: data.user.name }));
                        showToast(`✅ Login Berhasil! Autentikasi Admin Sah.`);
                        checkAdminAuth(); 
                    } else {
                        showToast(`❌ Akses ditolak! Akun ini bukan admin.`, true);
                    }
                } else {
                    showToast(`❌ ${data.message || 'Login gagal!'}`, true);
                }
            } catch (error) {
                showToast(`❌ Terjadi kesalahan jaringan.`, true);
            } finally {
                btn.innerText = "Log In Dashboard"; btn.disabled = false;
            }
        }

        function farmerLogout() { 
            localStorage.removeItem('agrihub_admin_auth'); 
            showToast("👋 Sesi Admin diakhiri."); checkAdminAuth(); 
        }

        // ==========================================
        // FITUR 1: FETCH DATA PRODUK (DENGAN EXPIRED)
        // ==========================================
        async function loadProducts() {
            const tableBody = document.getElementById('product-table-body');
            try {
                const res = await fetch('/api/products');
                const products = await res.json();
                tableBody.innerHTML = '';
                let totalAssetValue = 0;
                
                if (products.length === 0) { tableBody.innerHTML = '<tr><td colspan="4" class="p-4 text-center text-gray-500">Database kosong.</td></tr>'; return; }
                
                products.forEach(p => {
                    totalAssetValue += (p.price * p.stock);
                    
                    // Menghitung Masa Kedaluwarsa (Asumsi 7 Hari dari tanggal input)
                    let expireText = "<span class='text-gray-400'>N/A</span>";
                    let isExpiring = false;
                    let isExpired = false;

                    if (p.createdAt) {
                        // Handle format tanggal Firestore
                        const inputDate = new Date(p.createdAt._seconds ? p.createdAt._seconds * 1000 : p.createdAt);
                        const expireDate = new Date(inputDate.getTime() + (7 * 24 * 60 * 60 * 1000)); // +7 Hari
                        const today = new Date();
                        const timeDiff = expireDate.getTime() - today.getTime();
                        const daysLeft = Math.ceil(timeDiff / (1000 * 3600 * 24));

                        if (daysLeft < 0) {
                            isExpired = true;
                            expireText = `<span class="text-red-600 font-bold bg-red-50 px-2 py-1 rounded">Kadaluarsa</span>`;
                        } else if (daysLeft <= 2) {
                            isExpiring = true;
                            expireText = `<span class="text-yellow-600 font-bold bg-yellow-50 px-2 py-1 rounded">Sisa ${daysLeft} Hari</span>`;
                        } else {
                            expireText = `<span class="text-green-600 font-bold bg-green-50 px-2 py-1 rounded">Sisa ${daysLeft} Hari</span>`;
                        }
                    } else {
                        // Jika tidak ada data tanggal, buat data dummy "Sisa 5 Hari" untuk presentasi
                        expireText = `<span class="text-green-600 font-bold bg-green-50 px-2 py-1 rounded">Sisa 5 Hari</span>`;
                    }

                    // Fitur Upcycle untuk barang yang hampir expired atau sudah expired
                    const actionBtns = (isExpiring || isExpired)
                        ? `<button onclick="upcycleProduct('${p.id}', '${p.name}')" class="bg-yellow-500 text-white px-3 py-1.5 rounded text-xs font-bold shadow-md hover:bg-yellow-600 w-full mb-1">🔄 Upcycle to Pupuk</button>` 
                        : `<button onclick='editProduct(${JSON.stringify(p)})' class="text-blue-600 bg-blue-50 px-3 py-1 rounded text-xs font-bold mr-1">Edit</button><button onclick="deleteProduct('${p.id}')" class="text-red-600 bg-red-50 px-3 py-1 rounded text-xs font-bold">Hapus</button>`;

                    tableBody.innerHTML += `
                        <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
                            <td class="p-4 font-bold text-gray-900">${p.name} <br><span class="text-[10px] text-gray-400 font-normal">${p.category || '-'}</span></td>
                            <td class="p-4 text-xs">${expireText}</td>
                            <td class="p-4">
                                <span class="font-bold ${p.stock <= 5 ? 'text-red-600' : 'text-gray-900'}">${p.stock} Kg</span> <br>
                                <span class="text-xs text-gray-500">Rp ${p.price.toLocaleString('id-ID')}</span>
                            </td>
                            <td class="p-4 text-right align-middle">${actionBtns}</td>
                        </tr>
                    `;
                });
                document.getElementById('total-asset-value').innerText = `Rp ${(totalAssetValue/1000).toLocaleString('id-ID')}K`;
                document.getElementById('asset-count').innerText = `${products.length} Item`;
            } catch (error) {}
        }

        async function upcycleProduct(id, name) {
            if(confirm(`Kirim sisa stok [${name}] ke Mitra Pengolah Pupuk (Upcycle)?\nIni akan menghapusnya dari inventaris utama.`)) {
                await fetch(`/api/products/${id}`, { method: 'DELETE' }); 
                showToast(`♻️ ${name} berhasil disalurkan untuk dijadikan pupuk organik!`); 
                loadProducts(); 
            }
        }

        // ==========================================
        // FITUR 2: FETCH PESANAN & UBAH STATUS
        // ==========================================
        async function loadOrdersHistory() {
            const tableBody = document.getElementById('orders-table-body');
            try {
                const res = await fetch('/api/orders');
                const orders = await res.json();
                tableBody.innerHTML = '';
                
                if (orders.length === 0) { tableBody.innerHTML = '<tr><td colspan="4" class="p-4 text-center text-gray-500">Belum ada pesanan masuk.</td></tr>'; return; }
                
                // Urutkan dari yang terbaru
                orders.sort((a,b) => new Date(b.createdAt?._seconds ? b.createdAt._seconds * 1000 : b.createdAt) - new Date(a.createdAt?._seconds ? a.createdAt._seconds * 1000 : a.createdAt));
                
                orders.forEach(order => {
                    let orderItemsStr = '';
                    if (order.items) order.items.forEach(item => orderItemsStr += `<div class="text-xs text-gray-600">• ${item.productName || 'Produk'} <span class="font-bold">(${item.quantity} kg)</span></div>`);
                    
                    let dateStr = 'Baru saja';
                    if (order.createdAt) {
                        const d = new Date(order.createdAt._seconds ? order.createdAt._seconds * 1000 : order.createdAt);
                        dateStr = d.toLocaleDateString('id-ID', {day:'numeric', month:'short', hour:'2-digit', minute:'2-digit'});
                    }

                    // Tentukan warna badge dropdown berdasarkan status
                    let statusColor = "bg-yellow-100 text-yellow-700"; // Default Pending
                    if(order.status === "Diproses") statusColor = "bg-blue-100 text-blue-700 border-blue-200";
                    if(order.status === "Dikirim") statusColor = "bg-purple-100 text-purple-700 border-purple-200";
                    if(order.status === "Selesai") statusColor = "bg-green-100 text-green-700 border-green-200";

                    tableBody.innerHTML += `
                        <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
                            <td class="p-4"><span class="text-xs text-gray-500 font-medium">${dateStr}</span><br><span class="font-bold text-gray-900">${order.buyerName || 'Pembeli'}</span><br><span class="text-[10px] text-gray-500">${order.buyerPhone || ''}</span></td>
                            <td class="p-4">${orderItemsStr}</td>
                            <td class="p-4 font-bold text-[#165B33]">Rp ${(order.totalPrice || 0).toLocaleString('id-ID')}</td>
                            <td class="p-4 text-right">
                                <!-- DROPDOWN STATUS -->
                                <select onchange="updateOrderStatus('${order.id}', this.value)" class="status-dropdown text-xs font-bold rounded-lg px-3 py-2 border outline-none cursor-pointer shadow-sm transition ${statusColor}">
                                    <option value="Pending" ${order.status==='Pending'?'selected':''} class="bg-white text-gray-900">⏳ Pending</option>
                                    <option value="Diproses" ${order.status==='Diproses'?'selected':''} class="bg-white text-gray-900">📦 Diproses</option>
                                    <option value="Dikirim" ${order.status==='Dikirim'?'selected':''} class="bg-white text-gray-900">🚚 Dikirim</option>
                                    <option value="Selesai" ${order.status==='Selesai'?'selected':''} class="bg-white text-gray-900">✅ Selesai</option>
                                </select>
                            </td>
                        </tr>
                    `;
                });
            } catch (error) { tableBody.innerHTML = '<tr><td colspan="4" class="p-4 text-center text-red-500">Gagal memuat pesanan.</td></tr>'; }
        }

        // FUNGSI TEMBAK API UNTUK UPDATE STATUS PESANAN
        async function updateOrderStatus(orderId, newStatus) {
            try {
                // Menembak API updateOrder buatan temanmu (metode PUT)
                const res = await fetch(`/api/orders/${orderId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: newStatus })
                });

                if (res.ok) {
                    showToast(`📦 Status Pesanan berhasil diubah menjadi: ${newStatus}`);
                    loadOrdersHistory(); // Refresh tabel biar warnanya ganti
                } else {
                    showToast(`❌ Gagal mengubah status pesanan.`, true);
                }
            } catch (error) {
                showToast(`❌ Terjadi kesalahan jaringan.`, true);
            }
        }


        // ==========================================
        // 3. FUNGSI CRUD PRODUK (TANPA TOKEN)
        // ==========================================
        const modal = document.getElementById('crud-modal');
        const form = document.getElementById('product-form');
        
        function openProductModal() { form.reset(); document.getElementById('prod-id').value = ''; modal.classList.remove('hidden'); }
        function editProduct(product) {
            document.getElementById('prod-id').value = product.id; document.getElementById('prod-name').value = product.name;
            document.getElementById('prod-stock').value = product.stock; document.getElementById('prod-price').value = product.price;
            document.getElementById('prod-category').value = product.category || 'Vegetables'; modal.classList.remove('hidden');
        }
        function closeProductModal() { modal.classList.add('hidden'); }

        async function handleProductSubmit(e) {
            e.preventDefault(); 
            const id = document.getElementById('prod-id').value;
            const data = { name: document.getElementById('prod-name').value, stock: parseInt(document.getElementById('prod-stock').value), price: parseInt(document.getElementById('prod-price').value), category: document.getElementById('prod-category').value, seller: "Pusat", description: "Produk segar" };
            
            const btn = document.getElementById('btn-save-product');
            btn.innerText = "Menyimpan..."; btn.disabled = true;

            try {
                if (id) { 
                    await fetch(`/api/products/${id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) }); 
                    closeProductModal(); loadProducts(); showToast("✅ Produk diubah!"); 
                } else {
                    // Karena kamu sudah hapus verifyToken di backend, ini akan berjalan lancar tanpa token!
                    const res = await fetch('/api/products', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
                    if(res.ok) {
                        closeProductModal(); loadProducts(); showToast("✅ Produk baru sah ditambahkan! Masa Expired aktif 7 hari."); 
                    } else {
                        showToast("⚠️ Gagal! Cek console atau pastikan verifyToken sudah benar-benar dihapus di backend.", true);
                    }
                }
            } catch (error) { showToast("❌ Gagal menyimpan.", true); } finally { btn.innerText = "Simpan Data"; btn.disabled = false; }
        }

        async function deleteProduct(id) {
            if(confirm("Yakin hapus?")) { 
                await fetch(`/api/products/${id}`, { method: 'DELETE' }); 
                showToast("🗑️ Produk dihapus."); loadProducts(); 
            }
        }

        async function loadWeatherAPI() {
            try {
                const data = await (await fetch(`https://api.open-meteo.com/v1/forecast?latitude=-6.1783&longitude=106.6300&current=temperature_2m,weather_code&daily=weather_code,temperature_2m_max,temperature_2m_min&timezone=Asia%2FJakarta`)).json();
                document.getElementById('weather-current-temp').innerText = `${Math.round(data.current.temperature_2m)}°`;
                document.getElementById('weather-current-icon').innerText = "⛅";
                document.getElementById('weather-current-icon').classList.remove('animate-pulse');
            } catch (error) {}
        }
    </script>
</body>
</html>